@model List<WebsiteBanHang.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="container mt-5">
    <h2 class="mb-4">Giỏ hàng của bạn</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            Giỏ hàng của bạn đang trống. <a asp-controller="Home" asp-action="Index">Tiếp tục mua sắm</a>.
        </div>
    }
    else
    {
        <table class="table table-hover">
            <thead class="thead-light">
                <tr>
                    <th>Sản phẩm</th>
                    <th>Hình ảnh</th>
                    <th>Giá</th>
                    <th>Số lượng</th>
                    <th>Tổng cộng</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>
                            <img src="~/images/@(string.IsNullOrEmpty(item.ImageUrl) ? "default-product.png" : item.ImageUrl)" 
                                 alt="@item.Name" 
                                 style="width: 50px; height: 50px; object-fit: cover; border-radius: 8px;" />
                        </td>
                        <td>@item.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</td>
                        <td>
                            <form asp-action="UpdateQuantity" method="post" class="d-inline-flex">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <input type="number" name="quantity" value="@item.Quantity" min="1" class="form-control form-control-sm" style="width: 70px;" onchange="this.form.submit()" />
                            </form>
                        </td>
                        <td>@((item.Price * item.Quantity).ToString("C0", new System.Globalization.CultureInfo("vi-VN")))</td>
                        <td>
                            <a asp-action="RemoveFromCart" asp-route-productId="@item.ProductId" class="btn btn-danger btn-sm">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="4" class="text-right font-weight-bold">Tổng cộng:</td>
                    <td colspan="2" class="font-weight-bold text-primary">@Model.Sum(x => x.Price * x.Quantity).ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</td>
                </tr>
            </tfoot>
        </table>

        <div class="text-right mt-3">
            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary mr-2">Tiếp tục mua sắm</a>
            <a asp-action="Checkout" class="btn btn-success">Thanh toán</a>
        </div>
    }
</div>
