@model WebsiteBanHang.Models.Product

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Sản phẩm</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="card shadow border-0 rounded-4 overflow-hidden">
        <div class="row g-0">
            <div class="col-md-5 bg-light d-flex flex-column align-items-center justify-content-center p-4">
                <div class="position-relative w-100 shadow-sm rounded-3 overflow-hidden mb-3" style="max-height: 500px;">
                    <img id="mainProductImage" src="~/images/@Model.ImageUrl" 
                         alt="@Model.Name" 
                         class="img-fluid w-100" 
                         style="object-fit: cover; transition: transform 0.5s;"
                         onmouseover="this.style.transform='scale(1.05)'"
                         onmouseout="this.style.transform='scale(1)'"/>
                </div>

                @if (Model.Images != null && Model.Images.Any())
                {
                    <div class="d-flex flex-wrap gap-2 w-100 justify-content-center mt-2">
                        @foreach(var img in Model.Images)
                        {
                            <img src="~/images/@img.Url" 
                                 class="img-thumbnail shadow-sm cursor-pointer thumbnail-img" 
                                 style="width: 80px; height: 80px; object-fit: cover; cursor: pointer; transition: 0.2s;"
                                 onmouseover="this.style.opacity=0.7"
                                 onmouseout="this.style.opacity=1"
                                 onclick="document.getElementById('mainProductImage').src=this.src;" />
                        }
                    </div>
                }
            </div>

            <div class="col-md-7">
                <div class="card-body p-5">
                    <div class="mb-3">
                        <span class="badge bg-primary px-3 py-2 rounded-pill mb-2">Mã SP: #@Model.Id</span>
                        <h1 class="display-5 fw-bold text-dark mb-1">@Model.Name</h1>
                        <p class="text-muted fs-5">Danh mục: <span class="fw-bold">@Model.CategoryId</span></p>
                    </div>

                    <div class="mb-4">
                        <h2 class="text-danger fw-bold display-6">
                            @Model.Price.ToString("#,##0") <small class="fs-4">VNĐ</small>
                        </h2>
                    </div>

                    <div class="row mb-4">
                        <div class="col-6">
                            <h6 class="text-uppercase text-muted fw-bold small">Kích cỡ</h6>
                            <span class="badge bg-outline-dark border text-dark fs-6 px-4 py-2">
                                @Model.Size
                            </span>
                        </div>
                        <div class="col-6">
                            <h6 class="text-uppercase text-muted fw-bold small">Màu sắc</h6>
                            <div class="d-flex align-items-center">
                                <span class="badge bg-light border text-dark fs-6 px-4 py-2">
                                    @Model.Color
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4 pb-3 border-bottom">
                        <h6 class="text-uppercase text-muted fw-bold small">Mô tả sản phẩm</h6>
                        <p class="text-dark lh-base">
                            @Model.Description
                        </p>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-warning btn-lg px-4 shadow-sm">
                                <i class="fas fa-edit me-2"></i> Chỉnh sửa
                            </a>
                        }
                        <button class="btn btn-dark btn-lg px-4 shadow-sm">
                            <i class="fas fa-shopping-cart me-2"></i> Thêm vào giỏ
                        </button>
                        <a asp-controller="Home" asp-action="Products" class="btn btn-outline-secondary btn-lg px-4">
                            <i class="fas fa-arrow-left me-2"></i> Tiếp tục mua sắm
                        </a>
                    </div>
                    
                    <div class="mt-4 pt-4 text-muted small border-top">
                        <div class="row">
                            <div class="col-6">
                                <i class="fas fa-truck-moving me-2"></i> Giao hàng tận nơi
                            </div>
                            <div class="col-6">
                                <i class="fas fa-undo me-2"></i> Đổi trả trong 7 ngày
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>