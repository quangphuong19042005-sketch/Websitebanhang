@model IEnumerable<WebsiteBanHang.Models.Product>

@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

<style>
    .product-img-zoom {
        transition: transform 0.3s ease;
        cursor: pointer;
    }
    .product-img-zoom:hover {
        transform: scale(1.1); /* Phóng to nhẹ khi rê chuột */
    }
    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
        transition: 0.2s;
    }
</style>

<div class="container-fluid py-4 px-4">
    
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h2 class="fw-bold text-dark mb-1">📦 Quản Lý Kho Hàng</h2>
            <p class="text-muted mb-0">
                Hiện có <span class="badge bg-primary rounded-pill">@Model.Count()</span> sản phẩm trong hệ thống.
            </p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Add" class="btn btn-primary btn-lg shadow-sm px-4">
                <span class="fw-bold">+ Thêm Sản Phẩm Mới</span>
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        // TRƯỜNG HỢP 1: Chưa có sản phẩm nào (Danh sách trống)
        <div class="text-center py-5 bg-white rounded-3 shadow-sm">
            <h1 class="display-1 text-muted">📭</h1>
            <h4 class="text-muted">Chưa có sản phẩm nào!</h4>
            <p>Hãy thêm sản phẩm đầu tiên để bắt đầu bán hàng.</p>
            <a asp-action="Add" class="btn btn-success mt-3">Thêm ngay</a>
        </div>
    }
    else
    {
        // TRƯỜNG HỢP 2: Có sản phẩm -> Hiện bảng
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-body p-0">
                <table class="table align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="text-uppercase text-secondary text-xs fw-bolder" style="font-size: 0.8rem; letter-spacing: 1px;">
                            <th class="ps-4 py-3">Sản phẩm</th>
                            <th>Giá bán</th>
                            <th>Phân loại & Size</th>
                            <th>Mô tả</th>
                            <th class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="overflow-hidden rounded border" style="width: 70px; height: 70px;">
                                            <img src="~/images/@item.ImageUrl" 
                                                 alt="@item.Name" 
                                                 class="img-fluid w-100 h-100 product-img-zoom"
                                                 style="object-fit: cover;" />
                                        </div>
                                        <div class="ms-3">
                                            <h6 class="fw-bold mb-0 text-dark">@item.Name</h6>
                                            <small class="text-muted">ID: #@item.Id</small>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <span class="fw-bold text-success fs-6">
                                        @item.Price.ToString("#,##0") đ
                                    </span>
                                </td>

                                <td>
                                    <div class="d-flex flex-column gap-1">
                                        <span class="badge bg-light text-dark border">
                                            👗 Size: <strong>@item.Size</strong>
                                        </span>
                                        <span class="badge bg-light text-dark border">
                                            🎨 Màu: <strong>@item.Color</strong>
                                        </span>
                                    </div>
                                </td>

                                <td style="max-width: 250px;">
                                    <p class="text-muted small mb-0 text-truncate">
                                        @item.Description
                                    </p>
                                </td>

                                <td class="text-center">
                                    <div class="btn-group shadow-sm" role="group">
                                        <a asp-action="Display" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm" title="Xem chi tiết">
                                            📂
                                        </a>
                                        <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm" title="Chỉnh sửa">
                                            ✏️
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm" title="Xóa">
                                            🗑️
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            <div class="card-footer bg-white py-3 border-top-0 d-flex justify-content-end">
                <small class="text-muted fst-italic">Cập nhật lần cuối: Hôm nay</small>
            </div>
        </div>
    }
</div>