@model WebsiteBanHang.Models.Product

@{
    ViewData["Title"] = "Xác nhận xóa";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            
            <div class="card shadow border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-danger text-white py-3 text-center">
                    <h4 class="mb-0 fw-bold">⚠️ XÁC NHẬN XÓA SẢN PHẨM</h4>
                </div>
                
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <p class="fs-5 text-muted">Bạn có chắc chắn muốn xóa vĩnh viễn sản phẩm này không?</p>
                        <hr class="mx-auto" style="width: 50px;">
                    </div>

                    <div class="row align-items-center">
                        <div class="col-md-4 text-center mb-3 mb-md-0">
                            <div class="border rounded p-2 bg-light shadow-sm">
                                <img src="~/images/@Model.ImageUrl" 
                                     alt="@Model.Name" 
                                     class="img-fluid rounded" 
                                     style="max-height: 150px; object-fit: cover;" />
                            </div>
                        </div>

                        <div class="col-md-8">
                            <h3 class="fw-bold text-dark">@Model.Name</h3>
                            <p class="text-danger fw-bold fs-4 mb-1">@Model.Price.ToString("#,##0") VNĐ</p>
                            <p class="text-muted small mb-0"><strong>Kích cỡ:</strong> @Model.Size | <strong>Màu:</strong> @Model.Color</p>
                            <p class="text-muted mt-2 text-truncate" style="max-width: 100%;">@Model.Description</p>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex justify-content-center gap-3">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 fw-bold">
                            ❌ HỦY BỎ
                        </a>
                        
                        <form asp-action="DeleteConfirmed" method="post">
                            <input type="hidden" asp-for="Id" />
                            <button type="submit" class="btn btn-danger px-5 py-2 fw-bold shadow">
                                🗑️ XÁC NHẬN XÓA
                            </button>
                        </form>
                    </div>
                </div>

                <div class="card-footer bg-light py-2 text-center text-muted small">
                    Hành động này không thể hoàn tác. Hãy cẩn thận!
                </div>
            </div>

        </div>
    </div>
</div>