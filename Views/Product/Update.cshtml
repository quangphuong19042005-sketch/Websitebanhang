@model WebsiteBanHang.Models.Product

@{
    ViewData["Title"] = "Cập nhật sản phẩm";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-warning py-3">
                    <h4 class="mb-0 fw-bold text-dark">✏️ Chỉnh Sửa Sản Phẩm: @Model.Name</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Update" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ImageUrl" />

                        <div class="row">
                            <div class="col-md-7">
                                <div class="mb-3">
                                    <label asp-for="Name" class="form-label fw-bold">Tên sản phẩm</label>
                                    <input asp-for="Name" class="form-control shadow-sm" />
                                    <span asp-validation-for="Name" class="text-danger small"></span>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="Price" class="form-label fw-bold">Giá bán (VNĐ)</label>
                                        <input asp-for="Price" type="number" class="form-control shadow-sm" />
                                        <span asp-validation-for="Price" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="CategoryId" class="form-label fw-bold">Danh mục</label>
                                        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select shadow-sm"></select>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="Size" class="form-label fw-bold">Kích cỡ</label>
                                        <input asp-for="Size" class="form-control shadow-sm" />
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="Color" class="form-label fw-bold">Màu sắc</label>
                                        <input asp-for="Color" class="form-control shadow-sm" />
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
                                    <textarea asp-for="Description" class="form-control shadow-sm" rows="4"></textarea>
                                </div>
                            </div>

                            <div class="col-md-5 border-start ps-4">
                                <label class="form-label fw-bold text-primary">Hình ảnh sản phẩm</label>
                                
                                <div class="mb-3 text-center">
                                    <p class="small text-muted mb-1">Ảnh hiện tại:</p>
                                    <div class="d-flex flex-wrap gap-2 justify-content-center" id="currentImagesContainer">
                                        @if (Model.Images != null && Model.Images.Any())
                                        {
                                            foreach (var img in Model.Images)
                                            {
                                                <div class="position-relative d-inline-block" id="imageContainer-@img.Id">
                                                    <img src="~/images/@img.Url" class="img-thumbnail shadow-sm" style="height: 100px; object-fit: cover;" />
                                                    <button type="button" class="btn btn-danger btn-sm position-absolute top-0 start-100 translate-middle rounded-circle shadow" style="width: 25px; height: 25px; padding: 0; line-height: 1;" onclick="deleteImage(@img.Id)">
                                                        <i class="fas fa-times" style="font-size: 12px;">X</i>
                                                    </button>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <img src="~/images/@Model.ImageUrl" class="img-thumbnail shadow-sm" style="height: 100px; object-fit: cover;" />
                                        }
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="small fw-bold">Thêm ảnh mới (Ảnh cũ sẽ bị tải đè nếu có tải mới):</label>
                                    <input type="file" name="ImageFiles" class="form-control form-control-sm" id="imageInput" accept="image/*" multiple />
                                </div>

                                <div id="previewContainer" class="text-center d-none mt-2">
                                    <p class="small text-success mb-1">Ảnh mới chọn:</p>
                                    <div class="d-flex flex-wrap gap-2 justify-content-center" id="newImagesPreview">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between border-top mt-4 pt-3">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">🔙 Hủy bỏ</a>
                            <button type="submit" class="btn btn-warning btn-lg px-5 fw-bold shadow">Cập nhật ngay</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Xử lý xem trước ảnh khi người dùng chọn file mới
        // Xử lý xem trước nhiều ảnh
        document.getElementById('imageInput').onchange = function (evt) {
            const container = document.getElementById('previewContainer');
            const previewDiv = document.getElementById('newImagesPreview');
            previewDiv.innerHTML = '';
            
            if (this.files && this.files.length > 0) {
                container.classList.remove('d-none');
                document.getElementById('currentImagesContainer').style.opacity = "0.5";
                
                Array.from(this.files).forEach(file => {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        const img = document.createElement('img');
                        img.src = e.target.result;
                        img.className = 'img-thumbnail border-success';
                        img.style.height = '100px';
                        previewDiv.appendChild(img);
                    }
                    reader.readAsDataURL(file);
                });
            } else {
                container.classList.add('d-none');
                document.getElementById('currentImagesContainer').style.opacity = "1";
            }
        };

        function deleteImage(imageId) {
            if (confirm("Bạn có chắc chắn muốn xóa ảnh này?")) {
                fetch('/Product/DeleteImage', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: 'imageId=' + imageId
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        const container = document.getElementById('imageContainer-' + imageId);
                        if (container) {
                            container.remove();
                        }
                    } else {
                        alert("Lỗi khi xóa ảnh: " + data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert("Đã xảy ra lỗi khi xóa ảnh.");
                });
            }
        }
    </script>
}