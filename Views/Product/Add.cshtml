@model WebsiteBanHang.Models.Product

@{
    ViewData["Title"] = "Thêm sản phẩm mới";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-primary text-white py-3 text-center">
                    <h4 class="mb-0 fw-bold">✨ THÊM SẢN PHẨM MỚI</h4>
                </div>
                
                <div class="card-body p-4">
                    <form asp-action="Add" method="post" enctype="multipart/form-data">
                        
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label asp-for="Name" class="form-label fw-bold">Tên sản phẩm</label>
                                <input asp-for="Name" class="form-control shadow-sm" placeholder="Ví dụ: Áo thun Polo, Quần Tây Âu..." />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label fw-bold">Giá bán (VNĐ)</label>
                                <input asp-for="Price" type="number" class="form-control shadow-sm" placeholder="0" />
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="CategoryId" class="form-label fw-bold">Danh mục</label>
                                <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select shadow-sm border-primary"></select>
                                <small class="text-muted small">Hệ thống dựa vào đây để phân loại thư mục ảnh.</small>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Size" class="form-label fw-bold">Kích cỡ</label>
                                <input asp-for="Size" class="form-control shadow-sm" placeholder="S, M, L, XL, 32, 33..." />
                                <span asp-validation-for="Size" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Color" class="form-label fw-bold">Màu sắc</label>
                                <input asp-for="Color" class="form-control shadow-sm" placeholder="Trắng, Đen, Navy..." />
                                <span asp-validation-for="Color" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold text-primary">📸 Hình ảnh sản phẩm</label>
                                <div class="input-group shadow-sm">
                                    <input type="file" name="ImageFiles" class="form-control" accept="image/*" id="imageInput" multiple required />
                                </div>
                                
                                <div id="previewContainer" class="mt-3 text-center d-flex flex-wrap gap-2 d-none">
                                    <!-- Previews will be inserted here -->
                                </div>
                                
                                <div class="alert alert-info mt-2 py-2 small border-0 shadow-sm">
                                    <i class="fas fa-info-circle"></i> 
                                    <strong>Ghi chú:</strong> Ảnh sẽ được tự động lưu vào thư mục <code>images/ao</code> hoặc <code>images/quan</code> tương ứng với danh mục bạn chọn.
                                </div>
                            </div>

                            <div class="col-md-12 mb-4">
                                <label asp-for="Description" class="form-label fw-bold">Mô tả sản phẩm</label>
                                <textarea asp-for="Description" class="form-control shadow-sm" rows="3" placeholder="Nhập đặc điểm nổi bật của sản phẩm..."></textarea>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between border-top pt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 fw-bold">🔙 Quay lại</a>
                            <button type="submit" class="btn btn-primary btn-lg px-5 shadow fw-bold">🚀 LƯU SẢN PHẨM</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Script xem trước ảnh mượt mà
        // Script xem trước nhiều ảnh
        document.getElementById('imageInput').onchange = function (evt) {
            const container = document.getElementById('previewContainer');
            container.innerHTML = ''; // Xóa preview cũ
            
            if (this.files && this.files.length > 0) {
                container.classList.remove('d-none');
                
                Array.from(this.files).forEach((file, index) => {
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        const imgDiv = document.createElement('div');
                        imgDiv.className = 'position-relative d-inline-block';
                        
                        const img = document.createElement('img');
                        img.src = e.target.result;
                        img.className = 'img-thumbnail shadow';
                        img.style.maxHeight = '150px';
                        
                        if (index === 0) {
                            const badge = document.createElement('div');
                            badge.className = 'badge bg-success position-absolute top-0 start-100 translate-middle';
                            badge.textContent = 'Chính';
                            imgDiv.appendChild(badge);
                        }
                        
                        imgDiv.appendChild(img);
                        container.appendChild(imgDiv);
                        
                        imgDiv.animate([{ opacity: 0 }, { opacity: 1 }], { duration: 300, fill: 'forwards' });
                    }
                    reader.readAsDataURL(file);
                });
            } else {
                container.classList.add('d-none');
            }
        };
    </script>
}