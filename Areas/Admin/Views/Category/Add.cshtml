@model WebsiteBanHang.Models.Category

@{
    ViewData["Title"] = "Thêm danh mục";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm" style="border-radius: 12px;">
            <div class="card-header bg-white pt-4 px-4 border-0">
                <h5 class="fw-bold mb-0"><i class="fas fa-plus-circle text-primary me-2"></i>Thêm danh mục mới</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Add" method="post">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold small text-muted text-uppercase">Tên danh mục</label>
                        <input asp-for="Name" class="form-control" placeholder="Ví dụ: Quần Áo Nam" style="border-radius: 8px;" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="FolderName" class="form-label fw-semibold small text-muted text-uppercase">Thư mục ảnh</label>
                        <input asp-for="FolderName" class="form-control" placeholder="Ví dụ: nam, nu, phukien" style="border-radius: 8px;" />
                        <small class="text-muted">Tên thư mục lưu ảnh trong wwwroot/images/</small>
                    </div>
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-light px-4" style="border-radius: 8px;">
                            <i class="fas fa-arrow-left me-2"></i>Quay lại
                        </a>
                        <button type="submit" class="btn btn-primary px-4" style="border-radius: 8px;">
                            <i class="fas fa-save me-2"></i>Lưu danh mục
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
