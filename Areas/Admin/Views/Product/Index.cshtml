@model IEnumerable<WebsiteBanHang.Models.Product>

@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold text-dark mb-1">Quản lý sản phẩm</h4>
        <p class="text-muted mb-0" style="font-size: 0.85rem;">Hiện có <span class="fw-bold text-primary">@Model.Count()</span> sản phẩm trong kho</p>
    </div>
    <a asp-area="Admin" asp-controller="Product" asp-action="Add" class="btn btn-primary d-flex align-items-center gap-2 px-4 shadow-sm" style="border-radius: 8px;">
        <i class="fas fa-plus"></i> Thêm sản phẩm
    </a>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm text-center py-5" style="border-radius: 12px;">
        <div class="card-body">
            <i class="fas fa-box-open text-muted mb-3" style="font-size: 4rem; opacity: 0.3;"></i>
            <h5 class="fw-bold text-dark">Chưa có sản phẩm nào</h5>
            <p class="text-muted">Bắt đầu thêm sản phẩm để quản lý kho hàng của bạn.</p>
            <a asp-area="Admin" asp-controller="Product" asp-action="Add" class="btn btn-primary px-4" style="border-radius: 8px;">
                <i class="fas fa-plus me-2"></i>Thêm sản phẩm đầu tiên
            </a>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background: #f7f8fa;">
                    <tr>
                        <th class="ps-4 py-3 text-muted fw-semibold" style="font-size: 0.78rem; letter-spacing: 0.5px; text-transform: uppercase;">Sản phẩm</th>
                        <th class="py-3 text-muted fw-semibold" style="font-size: 0.78rem; letter-spacing: 0.5px; text-transform: uppercase;">Giá bán</th>
                        <th class="py-3 text-muted fw-semibold" style="font-size: 0.78rem; letter-spacing: 0.5px; text-transform: uppercase;">Danh mục</th>
                        <th class="py-3 text-muted fw-semibold" style="font-size: 0.78rem; letter-spacing: 0.5px; text-transform: uppercase;">Size / Màu</th>
                        <th class="py-3 text-muted fw-semibold text-end pe-4" style="font-size: 0.78rem; letter-spacing: 0.5px; text-transform: uppercase;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr style="border-bottom: 1px solid #f1f1f4;">
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div style="width: 48px; height: 48px; border-radius: 8px; overflow: hidden; flex-shrink: 0; background: #f5f5f5;">
                                        <img src="~/images/@(string.IsNullOrEmpty(item.ImageUrl) ? "default-product.png" : item.ImageUrl)"
                                             alt="@item.Name"
                                             style="width: 100%; height: 100%; object-fit: cover;" />
                                    </div>
                                    <div>
                                        <div class="fw-semibold text-dark" style="font-size: 0.9rem;">@item.Name</div>
                                        <div class="text-muted" style="font-size: 0.75rem;">ID: #@item.Id</div>
                                    </div>
                                </div>
                            </td>
                            <td class="py-3">
                                <span class="fw-bold text-dark">@item.Price.ToString("#,##0")</span>
                                <span class="text-muted" style="font-size: 0.8rem;">₫</span>
                            </td>
                            <td class="py-3">
                                <span class="badge rounded-pill" style="background: #f1faff; color: #3699ff; font-weight: 600; padding: 6px 12px;">
                                    @(item.Category?.Name ?? "—")
                                </span>
                            </td>
                            <td class="py-3">
                                @if (!string.IsNullOrEmpty(item.Size))
                                {
                                    <span class="badge bg-light text-dark border me-1" style="font-weight: 500;">@item.Size</span>
                                }
                                @if (!string.IsNullOrEmpty(item.Color))
                                {
                                    <span class="badge bg-light text-dark border" style="font-weight: 500;">@item.Color</span>
                                }
                            </td>
                            <td class="text-end pe-4 py-3">
                                <div class="d-flex justify-content-end gap-1">
                                    <a asp-area="Admin" asp-controller="Product" asp-action="Update" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-light d-flex align-items-center justify-content-center"
                                       style="width:34px; height:34px; border-radius:8px;"
                                       title="Sửa">
                                        <i class="fas fa-pen text-warning" style="font-size: 0.8rem;"></i>
                                    </a>
                                    <a asp-area="Admin" asp-controller="Product" asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-light d-flex align-items-center justify-content-center"
                                       style="width:34px; height:34px; border-radius:8px;"
                                       title="Xóa">
                                        <i class="fas fa-trash-alt text-danger" style="font-size: 0.8rem;"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-white border-top-0 px-4 py-3 d-flex justify-content-between align-items-center">
            <span class="text-muted" style="font-size: 0.82rem;">Tổng: <span class="fw-bold text-dark">@Model.Count()</span> sản phẩm</span>
        </div>
    </div>
}
