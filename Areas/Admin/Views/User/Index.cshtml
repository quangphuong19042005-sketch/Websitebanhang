@model IEnumerable<WebsiteBanHang.Models.ApplicationUser>

@{
    ViewData["Title"] = "Quản lý người dùng";
    var userRoles = ViewBag.UserRoles as Dictionary<string, IList<string>>;
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold text-dark mb-1">Quản lý người dùng</h4>
        <p class="text-muted mb-0" style="font-size: 0.85rem;">Hiện có <span class="fw-bold text-primary">@Model.Count()</span> tài khoản</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm py-2 mb-3" role="alert" style="border-radius: 8px;">
        <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm py-2 mb-3" role="alert" style="border-radius: 8px;">
        <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm" style="border-radius: 10px; border-left: 4px solid #3699ff !important;">
            <div class="card-body p-3 d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:40px; height:40px; background: rgba(54,153,255,0.1); flex-shrink:0;">
                    <i class="fas fa-users text-primary"></i>
                </div>
                <div>
                    <div class="text-muted" style="font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.5px;">Tổng người dùng</div>
                    <div class="fw-bold fs-5 text-dark">@Model.Count()</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm" style="border-radius: 10px; border-left: 4px solid #fd397a !important;">
            <div class="card-body p-3 d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:40px; height:40px; background: rgba(253,57,122,0.1); flex-shrink:0;">
                    <i class="fas fa-user-shield text-danger"></i>
                </div>
                <div>
                    <div class="text-muted" style="font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.5px;">Admin</div>
                    <div class="fw-bold fs-5 text-dark">@(userRoles?.Count(ur => ur.Value.Contains("Admin")) ?? 0)</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm" style="border-radius: 10px; border-left: 4px solid #1dc9b7 !important;">
            <div class="card-body p-3 d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:40px; height:40px; background: rgba(29,201,183,0.1); flex-shrink:0;">
                    <i class="fas fa-user text-success"></i>
                </div>
                <div>
                    <div class="text-muted" style="font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.5px;">Người dùng</div>
                    <div class="fw-bold fs-5 text-dark">@(userRoles?.Count(ur => !ur.Value.Contains("Admin")) ?? 0)</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- User Table -->
<div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead style="background: #f7f8fa;">
                <tr>
                    <th class="ps-4 py-3 text-muted fw-semibold" style="font-size: 0.78rem; letter-spacing: 0.5px; text-transform: uppercase;">Người dùng</th>
                    <th class="py-3 text-muted fw-semibold" style="font-size: 0.78rem; letter-spacing: 0.5px; text-transform: uppercase;">Vai trò</th>
                    <th class="py-3 text-muted fw-semibold" style="font-size: 0.78rem; letter-spacing: 0.5px; text-transform: uppercase;">Email xác nhận</th>
                    <th class="py-3 text-muted fw-semibold text-end pe-4" style="font-size: 0.78rem; letter-spacing: 0.5px; text-transform: uppercase;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    var roles = userRoles != null && userRoles.ContainsKey(user.Id) ? userRoles[user.Id] : new List<string>();
                    var isAdmin = roles.Contains("Admin");
                    var isCurrentUser = user.Email == User.Identity?.Name;

                    <tr style="border-bottom: 1px solid #f1f1f4;">
                        <td class="ps-4 py-3">
                            <div class="d-flex align-items-center gap-3">
                                <div style="width: 40px; height: 40px; border-radius: 10px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.85rem; color: #fff;
                                    background: @(isAdmin ? "linear-gradient(135deg, #fd397a, #ff6b6b)" : "linear-gradient(135deg, #3699ff, #0073e6)");">
                                    @(user.Email?.Substring(0, 1).ToUpper())
                                </div>
                                <div>
                                    <div class="fw-semibold text-dark" style="font-size: 0.9rem;">
                                        @user.Email
                                        @if (isCurrentUser)
                                        {
                                            <span class="badge bg-light text-muted ms-1" style="font-size: 0.65rem;">Bạn</span>
                                        }
                                    </div>
                                    <div class="text-muted" style="font-size: 0.72rem;">@user.UserName</div>
                                </div>
                            </div>
                        </td>
                        <td class="py-3">
                            @if (isAdmin)
                            {
                                <span class="badge rounded-pill" style="background: rgba(253,57,122,0.1); color: #fd397a; font-weight: 600; padding: 6px 12px;">
                                    <i class="fas fa-shield-alt me-1"></i>Admin
                                </span>
                            }
                            else
                            {
                                <span class="badge rounded-pill" style="background: rgba(54,153,255,0.1); color: #3699ff; font-weight: 600; padding: 6px 12px;">
                                    <i class="fas fa-user me-1"></i>User
                                </span>
                            }
                        </td>
                        <td class="py-3">
                            @if (user.EmailConfirmed)
                            {
                                <span class="text-success"><i class="fas fa-check-circle me-1"></i>Đã xác nhận</span>
                            }
                            else
                            {
                                <span class="text-warning"><i class="fas fa-clock me-1"></i>Chờ xác nhận</span>
                            }
                        </td>
                        <td class="text-end pe-4 py-3">
                            <div class="d-flex justify-content-end gap-1">
                                <form asp-action="ToggleAdmin" method="post" class="d-inline">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="btn btn-sm btn-light d-flex align-items-center justify-content-center"
                                            style="width:34px; height:34px; border-radius:8px;"
                                            title="@(isAdmin ? "Gỡ Admin" : "Gán Admin")"
                                            @(isCurrentUser ? "disabled" : "")>
                                        <i class="fas fa-user-cog @(isAdmin ? "text-warning" : "text-primary")" style="font-size: 0.8rem;"></i>
                                    </button>
                                </form>
                                <form asp-action="Delete" method="post" class="d-inline"
                                      onsubmit="return confirm('Bạn có chắc muốn xóa tài khoản @user.Email?')">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="btn btn-sm btn-light d-flex align-items-center justify-content-center"
                                            style="width:34px; height:34px; border-radius:8px;"
                                            title="Xóa tài khoản"
                                            @(isCurrentUser ? "disabled" : "")>
                                        <i class="fas fa-trash-alt text-danger" style="font-size: 0.8rem;"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
