@model IEnumerable<WebsiteBanHang.Models.Order>

@{
    ViewData["Title"] = "Quản lý Đơn hàng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold text-dark mb-1">Quản lý Đơn hàng</h4>
        <p class="text-muted mb-0" style="font-size: 0.85rem;">Hiện có <span class="fw-bold text-primary">@Model.Count()</span> đơn hàng trong hệ thống</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm text-center py-5" style="border-radius: 12px;">
        <div class="card-body">
            <i class="fas fa-shopping-basket text-muted mb-3" style="font-size: 4rem; opacity: 0.3;"></i>
            <h5 class="fw-bold text-dark">Chưa có đơn hàng nào</h5>
            <p class="text-muted">Đơn hàng mới từ khách hàng sẽ xuất hiện tại đây.</p>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background: #f7f8fa;">
                    <tr>
                        <th class="ps-4 py-3 text-muted fw-semibold" style="font-size: 0.78rem; letter-spacing: 0.5px; text-transform: uppercase;">Mã ĐH</th>
                        <th class="py-3 text-muted fw-semibold" style="font-size: 0.78rem; letter-spacing: 0.5px; text-transform: uppercase;">Khách hàng</th>
                        <th class="py-3 text-muted fw-semibold" style="font-size: 0.78rem; letter-spacing: 0.5px; text-transform: uppercase;">Ngày đặt</th>
                        <th class="py-3 text-muted fw-semibold" style="font-size: 0.78rem; letter-spacing: 0.5px; text-transform: uppercase;">Tổng tiền</th>
                        <th class="py-3 text-muted fw-semibold" style="font-size: 0.78rem; letter-spacing: 0.5px; text-transform: uppercase;">Trạng thái</th>
                        <th class="py-3 text-muted fw-semibold text-end pe-4" style="font-size: 0.78rem; letter-spacing: 0.5px; text-transform: uppercase;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr style="border-bottom: 1px solid #f1f1f4;">
                            <td class="ps-4 py-3 fw-bold text-primary">#@order.Id</td>
                            <td class="py-3">
                                <div class="fw-semibold text-dark" style="font-size: 0.9rem;">@order.FullName</div>
                                <div class="text-muted" style="font-size: 0.75rem;">@order.PhoneNumber</div>
                            </td>
                            <td class="py-3 text-muted" style="font-size: 0.85rem;">
                                @order.OrderDate.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td class="py-3">
                                <span class="fw-bold text-dark">@order.TotalPrice.ToString("#,##0")</span>
                                <span class="text-muted" style="font-size: 0.8rem;">₫</span>
                            </td>
                            <td class="py-3">
                                @switch (order.Status)
                                {
                                    case "Pending":
                                        <span class="badge rounded-pill" style="background: #f5f5f5; color: #5e6278; font-weight: 600; padding: 6px 12px;">Chờ duyệt</span>
                                        break;
                                    case "Processing":
                                        <span class="badge rounded-pill" style="background: #fff4e5; color: #ffa800; font-weight: 600; padding: 6px 12px;">Xử lý</span>
                                        break;
                                    case "Shipped":
                                        <span class="badge rounded-pill" style="background: #e1f0ff; color: #3699ff; font-weight: 600; padding: 6px 12px;">Đang giao</span>
                                        break;
                                    case "Completed":
                                        <span class="badge rounded-pill" style="background: #e8fff3; color: #50cd89; font-weight: 600; padding: 6px 12px;">Hoàn thành</span>
                                        break;
                                    case "Cancelled":
                                        <span class="badge rounded-pill" style="background: #fff5f8; color: #f1416c; font-weight: 600; padding: 6px 12px;">Đã hủy</span>
                                        break;
                                    default:
                                        <span class="badge rounded-pill bg-secondary" style="font-weight: 600; padding: 6px 12px;">@order.Status</span>
                                        break;
                                }
                            </td>
                            <td class="text-end pe-4 py-3">
                                <a asp-action="Details" asp-route-id="@order.Id" 
                                   class="btn btn-sm btn-light d-flex align-items-center justify-content-center ms-auto"
                                   style="width:34px; height:34px; border-radius:8px;"
                                   title="Xem chi tiết">
                                    <i class="fas fa-eye text-primary" style="font-size: 0.8rem;"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-white border-top-0 px-4 py-3 d-flex justify-content-between align-items-center">
            <span class="text-muted" style="font-size: 0.82rem;">Tổng cộng: <span class="fw-bold text-dark">@Model.Count()</span> đơn hàng</span>
        </div>
    </div>
}
