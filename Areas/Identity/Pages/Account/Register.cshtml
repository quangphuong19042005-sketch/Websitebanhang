@page
@model RegisterModel
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="row justify-content-center py-5">
    <div class="col-md-5 col-lg-4">
        <div class="card border-0 shadow-lg" style="border-radius: 16px; overflow: hidden;">
            <!-- Header -->
            <div class="text-center pt-5 pb-3 px-4" style="background: linear-gradient(135deg, #1e1e2d 0%, #2d2d3f 100%);">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                     style="width: 64px; height: 64px; background: rgba(29,201,183,0.15);">
                    <i class="fas fa-user-plus text-white" style="font-size: 1.5rem;"></i>
                </div>
                <h4 class="fw-bold text-white mb-1">Tạo tài khoản</h4>
                <p class="text-white-50 mb-0 small">Đăng ký để bắt đầu mua sắm</p>
            </div>

            <!-- Form -->
            <div class="card-body p-4">
                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Input.FullName" class="form-label fw-semibold small text-muted">HỌ VÀ TÊN</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fas fa-user text-muted"></i></span>
                            <input asp-for="Input.FullName" class="form-control border-start-0 bg-light" placeholder="Nguyễn Văn A" />
                        </div>
                        <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label fw-semibold small text-muted">EMAIL</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fas fa-envelope text-muted"></i></span>
                            <input asp-for="Input.Email" class="form-control border-start-0 bg-light" autocomplete="username" placeholder="you@example.com" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label fw-semibold small text-muted">MẬT KHẨU</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fas fa-lock text-muted"></i></span>
                            <input asp-for="Input.Password" class="form-control border-start-0 bg-light" autocomplete="new-password" placeholder="Tối thiểu 6 ký tự" />
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold small text-muted">XÁC NHẬN MẬT KHẨU</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fas fa-shield-alt text-muted"></i></span>
                            <input asp-for="Input.ConfirmPassword" class="form-control border-start-0 bg-light" autocomplete="new-password" placeholder="Nhập lại mật khẩu" />
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button id="registerSubmit" type="submit" class="btn btn-success w-100 fw-bold py-2 shadow-sm" style="border-radius: 10px;">
                        Đăng ký tài khoản <i class="fas fa-check ms-2"></i>
                    </button>
                </form>

                <div class="text-center mt-4 pt-3 border-top">
                    <p class="text-muted small mb-0">
                        Đã có tài khoản?
                        <a asp-page="./Login" class="fw-bold text-primary text-decoration-none">Đăng nhập</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
